# Repos to sweep for the weekly branch housekeeping, and the branches that must
# never be deleted in each. Add a new line to cover another repo.
#
# Format (pipe-separated): OWNER/REPO|comma,separated,protected,branches
#
# Protection is belt-and-braces: a branch is also protected if it is the repo's
# default branch or carries GitHub branch protection, regardless of this list.

# TRIAL: scoped to Umbraco-MCP-Base only while we shake the routine out.
# Re-enable the other two repos once the Base trial looks right.
HOUSEKEEPING_REPOS=(
  # "umbraco/Umbraco-CMS-MCP-Dev|main,dev,v16,v18/dev"
  "umbraco/Umbraco-MCP-Base|main,dev"
  # "umbraco/Umbraco-CMS-MCP-Editor|main,dev"
)
